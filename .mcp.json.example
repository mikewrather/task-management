{
    "mcpServers": {
        "agent-db": {
            "command": "uv",
            "args": [
                "run",
                "--directory",
                "/home/mike/development/project-agents",
                "project-agents-mcp"
            ],
            "env": {
                "NEO4J_PASSWORD": "agent-db-password",
                "NEO4J_ENCRYPTED": "false"
            }
        },
        "notion-task-management": {
            "command": "/home/mike/development/task-management/notion_mcp_server.py",
            "args": [],
            "cwd": "/home/mike/development/task-management",
            "env": {
                "PYTHONPATH": "/home/mike/development/task-management/src",
                "PATH": "/home/mike/development/task-management/.venv/bin:${PATH}"
            }
        },
        "notionApi": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "OPENAPI_MCP_HEADERS",
                "mcp/notion"
            ],
            "env": {
                "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_TOKEN}\",\"Notion-Version\":\"2022-06-28\"}"
            }
        }
    }
}