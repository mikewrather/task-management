# Voice Processing Configuration
OPENAI_API_KEY=sk-proj-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here  # Required for Claude AI processing
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# GraphRAG/Neo4j Configuration
# Authentication is handled by MCP agent-db server
# See .mcp.json for Neo4j connection details
USE_REAL_MCP=true           # Use real MCP vs mock for testing
USE_CLAUDE_PROCESSOR=true   # Enable intelligent Claude categorization
WRITE_TRANSCRIPT_FILE=true  # Write raw transcript markdown files under transcripts/

# File Cleanup Configuration
CLEANUP_PROCESSED_FILES=false  # Set to 'true' to enable cleanup tracking
CLEANUP_DELAY_HOURS=24         # Hours to wait before cleanup (default: 24)

# Archive Configuration
AUTO_ARCHIVE_PROCESSED_FILES=false  # Set to 'true' to automatically mark files for archive after processing
ARCHIVE_DELAY_DAYS=7                # Days to wait before auto-archiving (default: 7)
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=your-archive-folder-id  # Optional: separate archive folder

# Optional: Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFICATION_EMAIL=your-email@gmail.com

# Development/Debug
DEBUG=false  # Set to 'true' for detailed logging

# Legacy n8n Configuration (if needed)
N8N_CLOUD_API_KEY=your-api-key-here
N8N_CLOUD_WORKFLOW_ID=workflow-id-to-update